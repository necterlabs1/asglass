// Burraa MVP — SQLite (easy localhost dev, upgrade to PostgreSQL for production)
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Listing {
  id            Int       @id @default(autoincrement())
  title         String
  slug          String    @unique
  description   String
  shortDesc     String?
  location      String
  category      String
  price         Float
  originalPrice Float?
  discountPct   Int       @default(0)
  duration      String?
  groupSize     String?
  rating        Float     @default(4.5)
  coverImage    String?
  images        String    @default("[]")  // JSON array stored as string for SQLite
  isFeatured    Boolean   @default(false)
  isTrending    Boolean   @default(false)
  isActive      Boolean   @default(true)
  viewCount     Int       @default(0)
  inquiries     Inquiry[]
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Inquiry {
  id        Int      @id @default(autoincrement())
  name      String
  email     String
  phone     String?
  message   String
  listingId Int?
  listing   Listing? @relation(fields: [listingId], references: [id], onDelete: SetNull)
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
}
